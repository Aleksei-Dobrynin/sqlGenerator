    </None>
    <None Update="templates\%24table%24\%24table%24AddEditView\base.tsx.sbn">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="templates\%24table%24\%24table%24AddEditView\index.tsx.sbn">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="templates\%24table%24\%24table%24AddEditView\mtmTabs.tsx.sbn">
